direction: down

title: Proxy Startup Sequence {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

start: Start in proxy mode {
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.border-radius: 10
  style.shadow: true
}

cleanup: Cleanup stale socket {
  style.fill: "#E0E7FF"
  style.stroke: "#6366F1"
  style.border-radius: 10
}

connect: Try connect {
  style.fill: "#E0E7FF"
  style.stroke: "#6366F1"
  style.border-radius: 10
}

running: Daemon reachable? {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}

bridge_fast: Bridge stdio immediately {
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.border-radius: 10
}

lock: Acquire flock lock {
  style.fill: "#F5F3FF"
  style.stroke: "#8B5CF6"
  style.border-radius: 10
}

won: Lock acquired? {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}

double_check: Connect again {
  style.fill: "#FCE7F3"
  style.stroke: "#DB2777"
  style.border-radius: 10
}

race: Daemon appeared? {
  shape: diamond
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
}

spawn: Spawn `gatemini serve` {
  style.fill: "#EDE9FE"
  style.stroke: "#7C3AED"
  style.border-radius: 10
}

wait: Wait for socket {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 10
}

bridge: Bridge stdio {
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.border-radius: 10
  style.bold: true
}

other: Another proxy is spawning {
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.border-radius: 10
}

start -> cleanup -> connect -> running
running -> bridge_fast: yes
running -> lock: no

lock -> won
won -> double_check: yes
won -> other: no

double_check -> race
race -> bridge_fast: yes
race -> spawn: no

spawn -> wait -> bridge
other -> wait

note: |md
  The proxy keeps a cached MCP handshake so reconnect can replay initialization if the daemon restarts.
| {
  near: bottom-center
  style.font-size: 12
}
