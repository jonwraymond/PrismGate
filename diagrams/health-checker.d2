direction: down

title: Health Checker {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

loop: Run every `health.interval` {
  style.fill: "#E0F2FE"
  style.stroke: "#0284C7"
  style.border-radius: 12
  style.shadow: true
}

phase1: Phase 1 {
  label: "Phase 1: ping healthy backends"
  style.fill: "#ECFDF5"
  style.stroke: "#16A34A"
  style.border-radius: 12
}

phase2: Phase 2 {
  label: "Phase 2: recover unhealthy or stopped backends"
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
}

phase3: Phase 3 {
  label: "Phase 3: retry pending configured backends"
  style.fill: "#F5F3FF"
  style.stroke: "#7C3AED"
  style.border-radius: 12
}

phase1_detail: |md
  - stagger pings
  - timeout each ping
  - record success or failure
  - mark backend unhealthy after threshold
| {
  shape: page
  style.fill: "#F0FDF4"
  style.stroke: "#22C55E"
  style.font-size: 12
}

phase2_detail: |md
  - check recovery window
  - try half-open probe
  - or restart with backoff
  - re-check prerequisites first
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.font-size: 12
}

phase3_detail: |md
  Pending = configured backends
  that never became live.
| {
  shape: page
  style.fill: "#FAF5FF"
  style.stroke: "#8B5CF6"
  style.font-size: 12
}

settings: |md
  Defaults:

  - interval `30s`
  - timeout `5s`
  - threshold `3`
  - restart window `60s`
  - backoff `1s` to `30s`
| {
  shape: page
  style.fill: "#FEFCE8"
  style.stroke: "#CA8A04"
  style.font-size: 12
}

loop -> phase1 -> phase2 -> phase3
phase1 -> phase1_detail
phase2 -> phase2_detail
phase3 -> phase3_detail
phase2 -> settings
