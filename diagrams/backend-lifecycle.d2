title: Backend Lifecycle {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

starting: Starting {
  shape: oval
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.stroke-width: 2
}

healthy: Healthy {
  shape: oval
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.stroke-width: 2
}

unhealthy: Unhealthy {
  shape: oval
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.stroke-width: 2
}

stopped: Stopped {
  shape: oval
  style.fill: "#E2E8F0"
  style.stroke: "#475569"
  style.stroke-width: 2
}

starting -> healthy: handshake succeeded
starting -> stopped: start failed

healthy -> unhealthy: failures hit threshold
healthy -> stopped: process exited

unhealthy -> healthy: half-open probe succeeded
unhealthy -> starting: restart attempt
unhealthy -> stopped: restart budget exhausted

stopped -> starting: retry pending backend

note: |md
  Public states come from `BackendState`.

  Circuit-breaker timing is internal and maps back onto `Unhealthy` or `Stopped`.
| {
  near: bottom-center
  style.font-size: 13
}
