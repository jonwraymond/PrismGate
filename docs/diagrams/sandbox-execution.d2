direction: down

title: call_tool_chain Execution {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

input: User code or JSON {
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.border-radius: 12
  style.shadow: true
}

tier1: Tier 1 {
  label: "Direct JSON tool call"
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.border-radius: 12
}

tier2: Tier 2 {
  label: "Simple single-call TypeScript parse"
  style.fill: "#E0E7FF"
  style.stroke: "#6366F1"
  style.border-radius: 12
}

tier3: Tier 3 {
  label: "Full V8 sandbox"
  style.fill: "#F5F3FF"
  style.stroke: "#7C3AED"
  style.border-radius: 12
}

bridge: Dedicated V8 thread {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
}

bridge_note: |md
  - thread name `gatemini-sandbox`
  - 50 MiB default heap limit
  - tool calls hop back to Tokio
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.font-size: 12
}

introspection: Generated bridge objects {
  style.fill: "#F8FAFC"
  style.stroke: "#475569"
  style.border-radius: 12
}

introspection_note: |md
  - backend accessors
  - `__interfaces`
  - `__getToolInterface()`
| {
  shape: page
  style.fill: "#F8FAFC"
  style.stroke: "#64748B"
  style.font-size: 12
}

output: Output pipeline {
  style.fill: "#FEF9C3"
  style.stroke: "#CA8A04"
  style.border-radius: 12
}

output_detail: |md
  1. intent filter (>5KB + intent)
  2. auto-chunk JSON (>10KB)
  3. smart truncate (60/40 split)
  4. size metadata footer
| {
  shape: page
  style.fill: "#FEFCE8"
  style.stroke: "#EAB308"
  style.font-size: 12
}

trycatch: try/catch wrapper {
  label: "Thrown errors → return values"
  style.fill: "#FEF2F2"
  style.stroke: "#DC2626"
  style.border-radius: 12
  style.font-size: 12
}

input -> tier1: matches JSON shape
input -> tier2: matches simple TS call
input -> tier3: otherwise
tier3 -> bridge
tier3 -> trycatch: wraps user code
bridge -> bridge_note
bridge -> introspection
introspection -> introspection_note
tier1 -> output: raw result
tier2 -> output: raw result
tier3 -> output: raw result
output -> output_detail
