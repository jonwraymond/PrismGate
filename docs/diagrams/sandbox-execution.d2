direction: down

title: call_tool_chain Execution {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

input: User code or JSON {
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.border-radius: 12
  style.shadow: true
}

tier1: Tier 1 {
  label: "Direct JSON tool call"
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.border-radius: 12
}

tier2: Tier 2 {
  label: "Simple single-call TypeScript parse"
  style.fill: "#E0E7FF"
  style.stroke: "#6366F1"
  style.border-radius: 12
}

tier3: Tier 3 {
  label: "Full V8 sandbox"
  style.fill: "#F5F3FF"
  style.stroke: "#7C3AED"
  style.border-radius: 12
}

bridge: Dedicated V8 thread {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
}

bridge_note: |md
  - thread name `gatemini-sandbox`
  - 50 MiB default heap limit
  - tool calls hop back to Tokio
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.font-size: 12
}

introspection: Generated bridge objects {
  style.fill: "#F8FAFC"
  style.stroke: "#475569"
  style.border-radius: 12
}

introspection_note: |md
  - backend accessors
  - `__interfaces`
  - `__getToolInterface()`
| {
  shape: page
  style.fill: "#F8FAFC"
  style.stroke: "#64748B"
  style.font-size: 12
}

input -> tier1: matches JSON shape
input -> tier2: matches simple TS call
input -> tier3: otherwise
tier3 -> bridge
bridge -> bridge_note
bridge -> introspection
introspection -> introspection_note
