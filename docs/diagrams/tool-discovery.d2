direction: down

title: Progressive Tool Discovery {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

step1: Search {
  label: "1. search_tools(task_description)"
  style.fill: "#DBEAFE"
  style.stroke: "#2563EB"
  style.border-radius: 12
}

step1_note: |md
  Default output:

  - tool name
  - backend
  - short description
  - call example
| {
  shape: page
  style.fill: "#EFF6FF"
  style.stroke: "#60A5FA"
  style.font-size: 12
}

step2: Inspect {
  label: "2. tool_info(tool_name, detail='brief')"
  style.fill: "#E0E7FF"
  style.stroke: "#6366F1"
  style.border-radius: 12
}

step2_note: |md
  Brief mode returns:

  - name
  - backend
  - first sentence
  - parameter names
| {
  shape: page
  style.fill: "#EEF2FF"
  style.stroke: "#818CF8"
  style.font-size: 12
}

step3: Schema {
  label: "3. tool_info(tool_name, detail='full')"
  style.fill: "#F5F3FF"
  style.stroke: "#7C3AED"
  style.border-radius: 12
}

step3_note: Full JSON Schema on demand {
  style.fill: "#FAF5FF"
  style.stroke: "#8B5CF6"
  style.border-radius: 10
}

step4: Execute {
  label: "4. call_tool_chain(code)"
  style.fill: "#DCFCE7"
  style.stroke: "#16A34A"
  style.border-radius: 12
  style.bold: true
}

resources: Resource path {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
}

resources_note: |md
  `gatemini://tools`

  `gatemini://tool/{tool_name}`

  `gatemini://backends`
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.font-size: 12
}

step1 -> step1_note
step1 -> step2: found candidates
step2 -> step2_note
step2 -> step3: need full schema
step2 -> step4: enough info already
step3 -> step3_note
step3 -> step4: ready to call
step1 -> resources: client-driven context
resources -> resources_note
