direction: down

title: Daemon Lifecycle {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

bind: Early socket bind {
  style.fill: "#EDE9FE"
  style.stroke: "#7C3AED"
  style.border-radius: 12
  style.shadow: true
}

bind_detail: |md
  `bind_early()`

  - remove stale socket if needed
  - bind listener
  - write PID file
| {
  shape: page
  style.fill: "#F5F3FF"
  style.stroke: "#8B5CF6"
  style.font-size: 12
}

init: Shared initialization {
  style.fill: "#E0F2FE"
  style.stroke: "#0284C7"
  style.border-radius: 12
  style.shadow: true
}

init_detail: |md
  - load `.env`
  - load config
  - init tracing
  - resolve secrets
  - create tracker, registry, manager
  - load cache, aliases, composite tools
| {
  shape: page
  style.fill: "#F0F9FF"
  style.stroke: "#0EA5E9"
  style.font-size: 12
}

workers: Background workers {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
  style.shadow: true
}

workers_detail: |md
  - backend startup
  - health checker
  - config watcher
  - optional admin API
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#F97316"
  style.font-size: 12
}

accept: Accept loop {
  style.fill: "#ECFDF5"
  style.stroke: "#16A34A"
  style.border-radius: 12
  style.shadow: true
}

accept_detail: |md
  - accept client
  - spawn per-session server
  - update active-session count
  - reset idle timer
| {
  shape: page
  style.fill: "#F0FDF4"
  style.stroke: "#22C55E"
  style.font-size: 12
}

shutdown: Shutdown path {
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.border-radius: 12
  style.shadow: true
}

shutdown_detail: |md
  Triggered by:

  - idle timeout
  - `SIGTERM`
  - `SIGINT`

  Then:

  - drain clients
  - notify workers
  - stop backends
  - clean socket files
| {
  shape: page
  style.fill: "#FEF2F2"
  style.stroke: "#EF4444"
  style.font-size: 12
}

bind -> bind_detail
bind -> init
init -> init_detail
init -> workers
workers -> workers_detail
workers -> accept
accept -> accept_detail
accept -> shutdown
shutdown -> shutdown_detail

note: |md
  Proxies can connect after bind and wait while initialization finishes.
| {
  near: center-right
  style.font-size: 12
}
