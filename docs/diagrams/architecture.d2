direction: right

title: Gatemini Architecture Overview {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

clients: Clients {
  style.fill: "#E6F4F1"
  style.stroke: "#0F766E"
  style.border-radius: 12
  a: editor session
  b: terminal session
}

proxy: Proxy layer {
  style.fill: "#EFF6FF"
  style.stroke: "#2563EB"
  style.border-radius: 12
  p: stdio bridge + reconnect logic
}

daemon: Shared daemon {
  style.fill: "#F8FAFC"
  style.stroke: "#475569"
  style.border-radius: 12
  d1: registry
  d2: backend manager
  d3: session server
}

backends: Backend transports {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12
  s: stdio
  h: streamable-http
  c: cli-adapter
}

clients.a -> proxy.p
clients.b -> proxy.p
proxy.p -> daemon.d3
daemon.d2 -> backends.s
daemon.d2 -> backends.h
daemon.d2 -> backends.c
