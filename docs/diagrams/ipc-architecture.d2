direction: right

title: Gatemini IPC Architecture {
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}

clients: Client Sessions {
  style.fill: "#E6F4F1"
  style.stroke: "#0F766E"
  style.border-radius: 12

  c1: Claude Code
  c2: Codex
  c3: Cursor
}

proxies: Proxy Processes {
  style.fill: "#EFF6FF"
  style.stroke: "#2563EB"
  style.border-radius: 12

  p1: gatemini proxy
  p2: gatemini proxy
  p3: gatemini proxy
}

socket: Shared Unix Socket {
  shape: queue
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.border-radius: 12
}

paths: |md
  Linux: `$XDG_RUNTIME_DIR/gatemini.sock`

  macOS/fallback: `/tmp/gatemini-$UID.sock`
| {
  shape: page
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.font-size: 12
}

daemon: Shared Daemon {
  style.fill: "#F8FAFC"
  style.stroke: "#475569"
  style.border-radius: 12
  style.shadow: true

  init: Early-bound socket + shared init {
    style.fill: "#E2E8F0"
    style.border-radius: 8
  }
  server: MCP session server {
    style.fill: "#DBEAFE"
    style.stroke: "#2563EB"
    style.border-radius: 8
  }
  registry: Tool registry {
    style.fill: "#DCFCE7"
    style.stroke: "#16A34A"
    style.border-radius: 8
  }
  manager: Backend manager {
    style.fill: "#DCFCE7"
    style.stroke: "#16A34A"
    style.border-radius: 8
  }
  health: Health checker {
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
    style.border-radius: 8
  }
}

backends: Backend Transports {
  style.fill: "#FFF7ED"
  style.stroke: "#EA580C"
  style.border-radius: 12

  stdio: stdio child processes
  http: streamable-http services
  cli: cli-adapter commands
}

clients.c1 -> proxies.p1: stdio
clients.c2 -> proxies.p2: stdio
clients.c3 -> proxies.p3: stdio

proxies.p1 -> socket
proxies.p2 -> socket
proxies.p3 -> socket

socket -> daemon.server: shared session bridge {
  style.stroke-width: 3
}
socket -> paths: path rules

daemon.init -> daemon.registry
daemon.init -> daemon.manager
daemon.init -> daemon.health

daemon.manager -> backends.stdio: rmcp
daemon.manager -> backends.http: rmcp
daemon.manager -> backends.cli: subprocess

note: |md
  One daemon owns backend state.

  Proxies are disposable and can reconnect.
| {
  near: bottom-center
  style.font-size: 13
}
